# Server
PORT=3001
NODE_ENV=development

# Supabase - SET VIA 'fly secrets set' IN PRODUCTION
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT - SET VIA 'fly secrets set' IN PRODUCTION
JWT_SECRET=your-jwt-secret-min-32-charsuhdsjdhbsdjhbsdjhcbjdhcbsjcbehwbe8whdwjhecbjhdsbcjhdbwejhbwuecbwiecbwcbwdhibwicb031203u29d8h2ubd9o23dh23hd02o3hduo2n
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:5173,https://table-reservation-system-jade.vercel.app

# Email
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@tablereserve.app

# WARNING: This is a development .env only
# For production credentials, use: fly secrets set KEY=value
# DO NOT commit real credentials to this file